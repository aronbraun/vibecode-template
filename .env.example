# MongoDB connection string (e.g. from MongoDB Atlas).
# Leave empty to use an automatic in-memory MongoDB — development only:
# all data is lost on every restart, and the very first start downloads
# a MongoDB binary (can take a minute).
MONGODB_URI=

# Optional: Context7 API key (https://context7.com/dashboard) for higher rate
# limits on the docs-fetching MCP server configured in .mcp.json. Works without
# a key too. Note: MCP clients read this from your shell environment, not from
# this file — also export it in your shell profile if you set one.
CONTEXT7_API_KEY=
